{
  "name": "@repo/api",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:push": "drizzle-kit push",
    "db:seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.3.0",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.32.0",
    "hono": "^4.12.18",
    "jose": "^5.6.0",
    "postgres": "^3.4.4",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^25.8.0",
    "@types/uuid": "^10.0.0",
    "bun-types": "^1.3.14",
    "drizzle-kit": "^0.23.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}